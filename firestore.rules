rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function hasRoleDocument() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return hasRoleDocument()
        && currentUserRole() in ['super_admin', 'admin'];
    }

    function isSuperAdmin() {
      return hasRoleDocument()
        && currentUserRole() == 'super_admin';
    }

    match /users/{userId} {
      allow read: if isAuthenticated()
        && (request.auth.uid == userId || isAdmin());
      allow create, update, delete: if false;
    }

    match /bookings/{bookingId} {
      allow read, create, update, delete: if isAdmin();

      match /notes/{noteId} {
        allow read, create, update, delete: if isAdmin();
      }

      match /notifications/{notificationId} {
        allow read, create, update, delete: if isAdmin();
      }
    }

    match /settings/{settingId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if (resource.data.status == 'published' && resource.data.published == true) || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // Reserved for the future analytics module. The foundation does not write analytics yet.
    match /eventAnalytics/{eventId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
